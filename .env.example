# Application
NODE_ENV=development
PORT=8080
APP_URL=http://localhost:8080
WEB_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/surgerycare

# JWT Secrets (min 32 chars each — generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=

# File Storage (Cloudflare R2 / AWS S3 / Backblaze B2)
STORAGE_PROVIDER=r2
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# Payment Gateway (Razorpay)
PAYMENT_PROVIDER=razorpay
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Captcha (Cloudflare Turnstile)
CAPTCHA_PROVIDER=turnstile
TURNSTILE_SECRET_KEY=

# Job Queue
PG_BOSS_SCHEMA=pgboss

# Logging
LOG_LEVEL=info
