generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth / Users ───────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String        @map("password_hash")
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  phone         String?
  avatarUrl     String?       @map("avatar_url")
  accountStatus AccountStatus @default(PENDING_VERIFICATION) @map("account_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  userRoles          UserRole[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  donorProfile       DonorProfile?
  creatorProfile     CampaignCreatorProfile?
  adminProfile       AdminProfile?
  campaigns          Campaign[]
  donations          Donation[]
  notifications      Notification[]
  auditLogsAsActor   AuditLog[]             @relation("AuditActor")
  campaignUpdates    CampaignUpdate[]
  campaignReviews    CampaignReviewNote[]
  documentReviews    CampaignDocument[]     @relation("DocumentReviewer")
  withdrawalRequests WithdrawalRequest[]    @relation("WithdrawalRequester")
  withdrawalReviews  WithdrawalRequest[]    @relation("WithdrawalReviewer")
  disbursements      WithdrawalDisbursement[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      RoleType
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  family    String
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?  @map("user_agent")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

// ─── Profiles ───────────────────────────────────────────────────

model DonorProfile {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  displayName      String? @map("display_name")
  isAnonymous      Boolean @default(false) @map("is_anonymous")
  languagePreference String @default("en") @map("language_preference")
  contactPreference  String @default("email") @map("contact_preference")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donor_profiles")
}

model CampaignCreatorProfile {
  id                String  @id @default(uuid())
  userId            String  @unique @map("user_id")
  organizationName  String? @map("organization_name")
  bio               String?
  website           String?
  panNumber         String? @map("pan_number")
  bankAccountName   String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")
  bankIfsc          String? @map("bank_ifsc")
  bankName          String? @map("bank_name")
  kycStatus         String  @default("pending") @map("kyc_status")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("campaign_creator_profiles")
}

model AdminProfile {
  id         String  @id @default(uuid())
  userId     String  @unique @map("user_id")
  department String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─── Campaigns ──────────────────────────────────────────────────

model Campaign {
  id              String         @id @default(uuid())
  creatorId       String         @map("creator_id")
  title           String
  slug            String         @unique
  summary         String?
  description     String?
  goalAmount      Decimal        @map("goal_amount") @db.Decimal(12, 2)
  raisedAmount    Decimal        @default(0) @map("raised_amount") @db.Decimal(12, 2)
  currency        String         @default("INR")
  status          CampaignStatusEnum @default(DRAFT)
  category        String?
  urgencyLevel    String?        @map("urgency_level")
  coverImageUrl   String?        @map("cover_image_url")
  videoUrl        String?        @map("video_url")
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  publishedAt     DateTime?      @map("published_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  creator         User           @relation(fields: [creatorId], references: [id])
  medicalDetails  CampaignMedicalDetail?
  hospitalDetails CampaignHospitalDetail?
  documents       CampaignDocument[]
  updates         CampaignUpdate[]
  milestones      CampaignMilestone[]
  statusHistory   CampaignStatusHistory[]
  reviewNotes     CampaignReviewNote[]
  donations       Donation[]
  withdrawalRequests WithdrawalRequest[]

  @@index([status])
  @@index([creatorId])
  @@index([slug])
  @@map("campaigns")
}

model CampaignMedicalDetail {
  id              String   @id @default(uuid())
  campaignId      String   @unique @map("campaign_id")
  patientName     String   @map("patient_name")
  patientAge      Int?     @map("patient_age")
  patientGender   String?  @map("patient_gender")
  diagnosis       String?
  treatmentType   String?  @map("treatment_type")
  treatmentCost   Decimal? @map("treatment_cost") @db.Decimal(12, 2)
  doctorName      String?  @map("doctor_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_medical_details")
}

model CampaignHospitalDetail {
  id            String   @id @default(uuid())
  campaignId    String   @unique @map("campaign_id")
  hospitalName  String   @map("hospital_name")
  hospitalCity  String?  @map("hospital_city")
  hospitalState String?  @map("hospital_state")
  hospitalPhone String?  @map("hospital_phone")
  hospitalEmail String?  @map("hospital_email")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_hospital_details")
}

model CampaignDocument {
  id                 String         @id @default(uuid())
  campaignId         String         @map("campaign_id")
  uploaderId         String         @map("uploader_id")
  fileName           String         @map("file_name")
  fileType           String         @map("file_type")
  mimeType           String         @map("mime_type")
  fileSize           Int            @map("file_size")
  storageKey         String         @map("storage_key")
  checksum           String?
  verificationStatus DocumentStatusEnum @default(PENDING) @map("verification_status")
  reviewerId         String?        @map("reviewer_id")
  reviewNotes        String?        @map("review_notes")
  reviewedAt         DateTime?      @map("reviewed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewer User?    @relation("DocumentReviewer", fields: [reviewerId], references: [id])

  @@index([campaignId])
  @@map("campaign_documents")
}

model CampaignUpdate {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  authorId   String   @map("author_id")
  title      String
  content    String
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([campaignId])
  @@map("campaign_updates")
}

model CampaignMilestone {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  title       String
  description String?
  targetAmount Decimal? @map("target_amount") @db.Decimal(12, 2)
  reachedAt   DateTime? @map("reached_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_milestones")
}

model CampaignStatusHistory {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  fromStatus CampaignStatusEnum? @map("from_status")
  toStatus   CampaignStatusEnum  @map("to_status")
  changedBy  String?  @map("changed_by")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_status_history")
}

model CampaignReviewNote {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  reviewerId String   @map("reviewer_id")
  note       String
  action     String
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id])

  @@index([campaignId])
  @@map("campaign_review_notes")
}

// ─── Donations / Payments ───────────────────────────────────────

model Donation {
  id             String          @id @default(uuid())
  campaignId     String          @map("campaign_id")
  donorId        String?         @map("donor_id")
  donorName      String?         @map("donor_name")
  donorEmail     String?         @map("donor_email")
  amount         Decimal         @db.Decimal(12, 2)
  currency       String          @default("INR")
  isAnonymous    Boolean         @default(false) @map("is_anonymous")
  message        String?
  status         DonationStatusEnum @default(INITIATED)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  campaign       Campaign        @relation(fields: [campaignId], references: [id])
  donor          User?           @relation(fields: [donorId], references: [id])
  paymentIntent  PaymentIntent?
  receipt        DonationReceipt?

  @@index([campaignId])
  @@index([donorId])
  @@index([status])
  @@map("donations")
}

model PaymentIntent {
  id                String   @id @default(uuid())
  donationId        String   @unique @map("donation_id")
  provider          String
  providerIntentId  String?  @unique @map("provider_intent_id")
  providerOrderId   String?  @unique @map("provider_order_id")
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("INR")
  status            String   @default("created")
  providerPayload   Json?    @map("provider_payload")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  donation Donation @relation(fields: [donationId], references: [id])
  transactions PaymentTransaction[]

  @@map("payment_intents")
}

model PaymentTransaction {
  id                   String   @id @default(uuid())
  paymentIntentId      String   @map("payment_intent_id")
  providerTransactionId String  @unique @map("provider_transaction_id")
  provider             String
  amount               Decimal  @db.Decimal(12, 2)
  currency             String   @default("INR")
  status               String
  providerPayload      Json?    @map("provider_payload")
  createdAt            DateTime @default(now()) @map("created_at")

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id])

  @@map("payment_transactions")
}

model PaymentWebhookEvent {
  id              String   @id @default(uuid())
  provider        String
  eventType       String   @map("event_type")
  providerEventId String?  @unique @map("provider_event_id")
  payload         Json
  processed       Boolean  @default(false)
  processedAt     DateTime? @map("processed_at")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([provider, eventType])
  @@map("payment_webhook_events")
}

model RecurringDonation {
  id           String    @id @default(uuid())
  donorId      String    @map("donor_id")
  campaignId   String    @map("campaign_id")
  amount       Decimal   @db.Decimal(12, 2)
  currency     String    @default("INR")
  frequency    String    @default("monthly")
  status       String    @default("active")
  nextRunDate  DateTime  @map("next_run_date")
  lastRunDate  DateTime? @map("last_run_date")
  cancelledAt  DateTime? @map("cancelled_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([donorId])
  @@index([status, nextRunDate])
  @@map("recurring_donations")
}

model DonationReceipt {
  id            String   @id @default(uuid())
  donationId    String   @unique @map("donation_id")
  receiptNumber String   @unique @map("receipt_number")
  pdfStorageKey String?  @map("pdf_storage_key")
  issuedAt      DateTime @default(now()) @map("issued_at")
  createdAt     DateTime @default(now()) @map("created_at")

  donation Donation @relation(fields: [donationId], references: [id])

  @@map("donation_receipts")
}

// ─── Withdrawals / Finance ──────────────────────────────────────

model WithdrawalRequest {
  id             String              @id @default(uuid())
  campaignId     String              @map("campaign_id")
  requesterId    String              @map("requester_id")
  amount         Decimal             @db.Decimal(12, 2)
  currency       String              @default("INR")
  status         WithdrawalStatusEnum @default(REQUESTED)
  reason         String?
  reviewerId     String?             @map("reviewer_id")
  reviewNote     String?             @map("review_note")
  reviewedAt     DateTime?           @map("reviewed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  campaign       Campaign            @relation(fields: [campaignId], references: [id])
  requester      User                @relation("WithdrawalRequester", fields: [requesterId], references: [id])
  reviewer       User?               @relation("WithdrawalReviewer", fields: [reviewerId], references: [id])
  disbursements  WithdrawalDisbursement[]

  @@index([campaignId])
  @@index([status])
  @@map("withdrawal_requests")
}

model WithdrawalDisbursement {
  id                  String   @id @default(uuid())
  withdrawalRequestId String   @map("withdrawal_request_id")
  amount              Decimal  @db.Decimal(12, 2)
  currency            String   @default("INR")
  transactionRef      String?  @map("transaction_ref")
  disbursedBy         String   @map("disbursed_by")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  withdrawalRequest WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id])
  disburser         User              @relation(fields: [disbursedBy], references: [id])

  @@map("withdrawal_disbursements")
}

model ReconciliationReport {
  id          String   @id @default(uuid())
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  totalDonations Decimal @map("total_donations") @db.Decimal(12, 2)
  totalWithdrawals Decimal @map("total_withdrawals") @db.Decimal(12, 2)
  discrepancies Json?
  generatedBy String   @map("generated_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("reconciliation_reports")
}

// ─── Communication ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model EmailLog {
  id          String   @id @default(uuid())
  toEmail     String   @map("to_email")
  template    String
  subject     String
  status      String   @default("queued")
  provider    String?
  providerId  String?  @map("provider_id")
  error       String?
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([toEmail])
  @@map("email_logs")
}

// ─── Trust / Content ────────────────────────────────────────────

model PartnerHospital {
  id          String   @id @default(uuid())
  name        String
  city        String?
  state       String?
  logoUrl     String?  @map("logo_url")
  website     String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("partner_hospitals")
}

model BoardMember {
  id          String   @id @default(uuid())
  name        String
  title       String?
  bio         String?
  photoUrl    String?  @map("photo_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("board_members")
}

model AnnualReport {
  id          String   @id @default(uuid())
  year        Int      @unique
  title       String
  fileUrl     String   @map("file_url")
  storageKey  String   @map("storage_key")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("annual_reports")
}

model FundUtilizationEntry {
  id          String   @id @default(uuid())
  period      String
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("fund_utilization_entries")
}

model LocalizedContent {
  id        String   @id @default(uuid())
  slug      String
  locale    String   @default("en")
  title     String?
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, locale])
  @@map("localized_content")
}

// ─── Security / Audit ───────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ip         String?
  userAgent  String?  @map("user_agent")
  requestId  String?  @map("request_id")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Enums ──────────────────────────────────────────────────────

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum RoleType {
  VISITOR
  DONOR
  CAMPAIGN_CREATOR
  MODERATOR
  FINANCE_MANAGER
  SUPER_ADMIN
}

enum CampaignStatusEnum {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  ACTIVE
  PAUSED
  REJECTED
  COMPLETED
  CLOSED
}

enum DonationStatusEnum {
  INITIATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum DocumentStatusEnum {
  PENDING
  VERIFIED
  REJECTED
}

enum WithdrawalStatusEnum {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PARTIALLY_DISBURSED
  FULLY_DISBURSED
  CANCELLED
}
